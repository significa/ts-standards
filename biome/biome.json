{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "root": false,
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/.astro",
      "!**/.output",
      "!**/.vite",
      "!**/.next",
      "!**/dist",
      "!**/build",
      "!**/coverage",
      "!**/node_modules",
      "!**/.claude/settings.local.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "domains": {
      "project": "recommended",
      "react": "recommended",
      "test": "recommended"
    },
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsole": "warn"
      },
      "nursery": {
        "noFloatingPromises": "error"
      },
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "warn",
          "options": { "maxAllowedComplexity": 25 }
        }
      }
    }
  }
}
