{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@significa/tsconfig/astro",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "allowImportingTsExtensions": true
  },
  "include": ["${configDir}/.astro/types.d.ts", "${configDir}/**/*"],
  "exclude": ["${configDir}/dist"]
}
